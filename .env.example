# Configuração do Firebase para a Sondagem ERSVoix
# Renomeie este arquivo para .env.local e insira as credenciais do seu projeto Firebase.

VITE_FIREBASE_API_KEY=sua-api-key
VITE_FIREBASE_AUTH_DOMAIN=seu-auth-domain-aqui.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=seu-project-id-aqui
VITE_FIREBASE_STORAGE_BUCKET=seu-storage-bucket-aqui.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=seu-messaging-sender-id-aqui
VITE_FIREBASE_APP_ID=seu-app-id-aqui
